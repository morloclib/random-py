module random-py (*)

import random
import root-py


-- Typeclass instances
-----------------------

instance Random Real where
  %inline
  source Py from "core.py" ("morloc_random_real" as random)

instance Random Int where
  %inline
  source Py from "core.py" ("morloc_random_int" as random)

instance Random Bool where
  %inline
  source Py from "core.py" ("morloc_random_bool" as random)

instance RandomRange Real where
  %inline
  source Py from "core.py" ("morloc_randomRange_real" as randomRange)

instance RandomRange Int where
  %inline
  source Py from "core.py" ("morloc_randomRange_int" as randomRange)

instance RandomGroup List where
  %inline
  source Py from "core.py"
    ( "morloc_choice" as choice
    , "morloc_weightedChoice" as weightedChoice
    , "morloc_sample" as sample
    , "morloc_sampleWith" as sampleWith
    , "morloc_permute" as permute
    )


-- Standalone functions
------------------------

%inline
source Py from "core.py"
    ( "morloc_bernoulli" as bernoulli
    , "morloc_setSeed" as setSeed
    )
